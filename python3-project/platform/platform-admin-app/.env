# ============================================================
# Platform Admin App - Environment Configuration
# ============================================================
# ⚠️ 安全提示：生产环境必须修改所有密钥和默认密码！

# Application
APP_NAME=Platform Admin
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
# 开发环境密钥（生产环境必须替换为 ≥32 字节的随机字符串）
SECRET_KEY=dev-secret-key-must-be-replaced-in-production-12345678

# Database (default: SQLite as H2-equivalent embedded database)
# Supported: sqlite, mysql, postgresql
DB_TYPE=sqlite

# SQLite (default, H2-equivalent embedded database)
SQLITE_DB_FILE=data/platform_admin.db

# MySQL
# DB_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=platform_admin

# PostgreSQL
# DB_TYPE=postgresql
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=platform_admin

# JWT
# 开发环境密钥（生产环境必须替换为 ≥32 字节的随机字符串）
JWT_SECRET_KEY=dev-jwt-key-must-be-replaced-in-production-12345678
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Admin default credentials（首次初始化后建议删除或修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# Logging
# Supported levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log file directory (relative to project root, empty string to disable file logging)
LOG_DIR=logs
LOG_FILE=app.log

# Internal API Key（管理端与应用端之间的服务间通信密钥）
INTERNAL_API_KEY=internal-api-key-dev-must-be-replaced-in-production
