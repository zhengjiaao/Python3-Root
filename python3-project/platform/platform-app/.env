# ============================================================
# Platform App - Environment Configuration
# ============================================================
# 平台应用端环境配置：用户体系/权限完全依赖管理端（客户端），
# 通过内部 API 调用管理端完成认证、权限校验等操作。

# Application
APP_NAME=Platform App
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# 平台管理端地址（用于页面跳转或反向代理）
ADMIN_APP_URL=http://127.0.0.1:8000

# 管理端内部 API 密钥（必须与管理端 INTERNAL_API_KEY 一致）
ADMIN_APP_INTERNAL_API_KEY=internal-api-key-dev-must-be-replaced-in-production

# Application Server（与 admin 区分，避免端口冲突）
APP_HOST=127.0.0.1
APP_PORT=8001

# JWT（必须与管理端一致，否则 token 无法互通验证）
JWT_SECRET_KEY=dev-jwt-key-must-be-replaced-in-production-12345678
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=platform_app.log
